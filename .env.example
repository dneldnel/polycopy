# Leader wallet observed from public activity stream.
# In most cases this should be the leader proxy wallet address.
LEADER_WALLET_ADDRESS=0xLEADER_PROXY_WALLET

# Your follower profile/funder wallet address.
# FOLLOWER_WALLET_ADDRESS=0x000d257d2dc7616feaef4ae0f14600fdf50a758e # scottilicious
FOLLOWER_WALLET_ADDRESS=0x113d4c0b5a6702ab045ea2cba7c3f71d51fc3ce8 #charles-de-g

# Run in simulation first. Set to false for live order placement.
SIMULATION_MODE=true

# Order sizing:
# fixed -> always use FIXED_ORDER_SIZE
# multiplier -> leader_size * SIZE_MULTIPLIER
ORDER_SIZE_MODE=fixed
FIXED_ORDER_SIZE=5
SIZE_MULTIPLIER=1

# Proxy wallet setup.
WALLET_PRIVATE_KEY=
SIGNATURE_TYPE=POLY_GNOSIS_SAFE
PROXY_WALLET_ADDRESS=

# Optional explicit API creds. If omitted, the app will try derive/create.
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=

# Network / runtime options.
CLOB_HTTP_URL=https://clob.polymarket.com
CHAIN_ID=137
POLYCOPY_V2_DB_PATH=./data/polycopy-v2.sqlite
POLYCOPY_V2_TUI=true
